      "text": "def backspaceCompare(self, s: str, t: str) -> bool:\n    list_s = []\n    list_t = []\n    \n    is_s_empty = len(s) == 0\n    is_t_empty = len(t) == 0 \n    \n    for char in s:\n        if char != \"#\":\n            list_s.append(s)\n        elif :\n          list_s.pop\n       return list_s\n\n    for char in s:\n        if char != \"#\":\n            list_s.append(s)\n        elif :\n          list_s.pop\n       return list_s\n            ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "def backspaceCompare(self, s: str, t: str) -> bool:\n    list_s = []\n    list_t = []\n    \n    is_s_empty = len(s) == 0\n    is_t_empty = len(t) == 0 \n    \n    for char in s:\n        if char != \"#\":\n            list_s.append(s)\n        elif :\n          list_s.pop\n       return list_s\n\n    for char in s:\n        if char != \"#\":\n            list_s.append(s)\n        elif :\n          list_s.pop\n       return list_s\n            ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TfBjY6LiFq5YcY20pwaSL",
      "type": "text",
      "x": 994.1217033276338,
