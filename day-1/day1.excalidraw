      "link": null,
      "locked": false,
      "text": "def backspaceCompare(self, s: str, t: str) -> bool:\n    list_s = []  s = \"ab#c\" -> [a, c]\n    list_t = [] -> (s+t) -> O(n)\n    \n    \n    for char in s:\n        \n        if list_s and char == '#':\n            list_s.pop()\n        elif:\n          list_s.append(char)\n\n    for char in t:\n      if list_t and char == '#':\n            list_t.pop()\n        elif:\n          list_t.append(char)\n\nreturn list_s == list_t -> [a, c] == [a, c] \n            ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "def backspaceCompare(self, s: str, t: str) -> bool:\n    list_s = []  s = \"ab#c\" -> [a, c]\n    list_t = [] -> (s+t) -> O(n)\n    \n    \n    for char in s:\n        \n        if list_s and char == '#':\n            list_s.pop()\n        elif:\n          list_s.append(char)\n\n    for char in t:\n      if list_t and char == '#':\n            list_t.pop()\n        elif:\n          list_t.append(char)\n\nreturn list_s == list_t -> [a, c] == [a, c] \n            ",
      "autoResize": true,
      "lineHeight": 1.25
    },
